# Per-instance validation logs (regenerated by validate_instance.sh)
instances/*/.validation/

# Auto-generated CSVs (regenerated by validate_all.sh)
validation_summary.csv

# Compiled harness binaries (rebuilt by build_sh_*); only the .c source is checked in
instances/*/repro/harness_*
!instances/*/repro/harness_*.c
!instances/*/repro/harness_*.cpp
!instances/*/repro/harness_*.py
!instances/*/repro/harness_*.sh
